.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f4f1e7;
}

.map-wrap {
  position: relative;
  height: 48vh;
  min-height: 560rpx;
  border-bottom: 1rpx solid rgba(92, 74, 47, 0.18);
}

.map {
  width: 100%;
  height: 100%;
}

.map-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  min-width: 132rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid rgba(35, 79, 68, 0.16);
  background: rgba(255, 250, 240, 0.92);
  box-shadow: 0 12rpx 24rpx rgba(27, 42, 38, 0.12);
  color: #66746b;
  font-size: 22rpx;
  text-align: center;
}

.map-badge-number {
  display: block;
  color: #182420;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.panel {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-mark {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 8rpx solid #255848;
  box-shadow: inset 0 0 0 5rpx #d1a24a;
}

.eyebrow,
.label {
  display: block;
  color: #6d776f;
  font-size: 23rpx;
}

.title {
  display: block;
  color: #182420;
  font-size: 38rpx;
  font-weight: 900;
}

.status-card,
.search-panel,
.transport-panel,
.route-list {
  border: 1rpx solid rgba(92, 74, 47, 0.18);
  background: rgba(255, 250, 240, 0.74);
  padding: 22rpx;
}

.status-title {
  display: block;
  margin-top: 8rpx;
  color: #182420;
  font-size: 33rpx;
  font-weight: 900;
}

.status-hint {
  display: block;
  margin-top: 8rpx;
  color: #66746b;
  font-size: 25rpx;
  line-height: 1.45;
}

.search-box {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(92, 74, 47, 0.22);
  background: rgba(255, 255, 255, 0.62);
}

.search-box input {
  flex: 1;
  height: 76rpx;
  padding: 0 18rpx;
  color: #182420;
  font-size: 27rpx;
}

.clear-search {
  width: 72rpx;
  min-height: 72rpx;
  border: 0;
  background: transparent;
  color: #a7352d;
}

.search-results {
  margin-top: 12rpx;
  display: grid;
  gap: 8rpx;
}

.search-result {
  padding: 14rpx 16rpx;
  border: 1rpx solid rgba(35, 79, 68, 0.14);
  background: rgba(255, 255, 255, 0.58);
  text-align: left;
}

.search-result text {
  display: block;
}

.search-result text:first-child {
  color: #182420;
  font-size: 27rpx;
  font-weight: 800;
}

.search-result text:last-child {
  margin-top: 4rpx;
  color: #66746b;
  font-size: 22rpx;
}

.transport-toggle,
.controls {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.transport-option,
.controls button {
  min-height: 76rpx;
  border: 1rpx solid rgba(92, 74, 47, 0.24);
  background: rgba(255, 250, 240, 0.72);
  color: #255848;
  font-weight: 800;
}

.transport-option.active {
  background: #255848;
  color: #fffaf0;
}

.danger {
  color: #a7352d !important;
}

.summary {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  border: 1rpx solid rgba(92, 74, 47, 0.18);
}

.summary view {
  min-height: 120rpx;
  padding: 20rpx;
  border-right: 1rpx solid rgba(92, 74, 47, 0.18);
  border-bottom: 1rpx solid rgba(92, 74, 47, 0.18);
  background: rgba(255, 250, 240, 0.56);
}

.summary text {
  display: block;
  color: #66746b;
  font-size: 23rpx;
}

.summary-value {
  display: block;
  margin-top: 10rpx;
  color: #182420;
  font-size: 42rpx;
  line-height: 1;
}

.route-heading {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 18rpx;
  color: #182420;
  font-size: 32rpx;
  font-weight: 900;
}

.chain {
  min-width: 0;
  overflow: hidden;
  color: #66746b;
  font-size: 23rpx;
  font-weight: 500;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-list {
  display: grid;
  gap: 12rpx;
}

.route-item {
  padding: 18rpx;
  border: 1rpx solid rgba(22, 143, 125, 0.28);
  background: rgba(255, 255, 255, 0.48);
}

.segment {
  display: block;
  overflow: hidden;
  color: #182420;
  font-size: 28rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-status,
.meta,
.empty {
  display: block;
  margin-top: 8rpx;
  color: #66746b;
  font-size: 23rpx;
  line-height: 1.45;
}
